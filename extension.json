{
  "id": "search",
  "name": "Search",
  "version": "0.1.0",
  "category": "feature",
  "authors": [
    "Bias"
  ],
  "dependencies": [
    "core",
    "content",
    "users"
  ],
  "optional_dependencies": [
    "discussions",
    "posts",
    "tags"
  ],
  "django": {
    "app_config": "bias_ext_search.backend.apps.SearchExtensionConfig",
    "app_label": "search",
    "migration_module": "bias_ext_search.backend.django_migrations"
  },
  "backend": {
    "entry": "bias_ext_search.backend.ext"
  },
  "extra": {
    "auto_install": true,
    "auto_enable": true
  },
  "performance_contracts": [
    {
      "name": "search_driver_boundary",
      "message": "database search uses PostgreSQL full text only when supported and keeps extension targets behind runtime services.",
      "database_boundary": "SearchService.should_use_postgres_full_text",
      "extension_boundary": "search.target.* runtime services"
    }
  ],
  "security": {
    "capabilities_notice": "Search extension; indexes and queries discussion, post, tag, and user-visible content."
  }
}
